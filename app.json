{
  "expo": {
    "name": "BUGGY",
    "slug": "buggy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/buggyicon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",

    "ios": {
      "supportsTablet": true
    },

    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },

    "web": {
      "bundler": "metro",
      "output": "server",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://uber.dev/"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#2F80ED"
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true
    }
  }
}